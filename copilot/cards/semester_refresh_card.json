{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "New Semester Check-in",
      "size": "Medium",
      "weight": "Bolder",
      "color": "Accent"
    },
    {
      "type": "TextBlock",
      "text": "A new semester has started. Anything to update?",
      "wrap": true,
      "spacing": "Small"
    },
    {
      "type": "Input.Number",
      "id": "gpa",
      "label": "Updated CGPA",
      "placeholder": "e.g. 3.8"
    },
    {
      "type": "Input.ChoiceSet",
      "id": "year_of_study",
      "label": "Year of Study",
      "style": "compact",
      "choices": [
        {"title": "Year 1", "value": "1"},
        {"title": "Year 2", "value": "2"},
        {"title": "Year 3", "value": "3"},
        {"title": "Year 4", "value": "4"},
        {"title": "Year 5+", "value": "5"},
        {"title": "Postgraduate", "value": "postgraduate"}
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Update profile",
      "style": "positive",
      "data": {"action": "semester_refresh_submit"}
    },
    {
      "type": "Action.Submit",
      "title": "Nothing changed",
      "data": {"action": "semester_refresh_dismiss"}
    }
  ]
}
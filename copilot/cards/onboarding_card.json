{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.0",
  "body": [
    {
      "type": "TextBlock",
      "text": "Welcome to HKU Campus Agent",
      "size": "Large",
      "weight": "Bolder",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Set up your profile so I can personalize scholarships, events, and inbox management.",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Basic Info",
      "weight": "Bolder",
      "separator": true
    },
    { "type": "TextBlock", "text": "Faculty", "wrap": true },
    {
      "type": "Input.ChoiceSet",
      "id": "faculty",
      "style": "compact",
      "choices": [
        { "title": "Architecture", "value": "Architecture" },
        { "title": "Arts", "value": "Arts" },
        { "title": "Business and Economics", "value": "Business and Economics" },
        { "title": "Dentistry", "value": "Dentistry" },
        { "title": "Education", "value": "Education" },
        { "title": "Engineering", "value": "Engineering" },
        { "title": "Law", "value": "Law" },
        { "title": "Medicine", "value": "Medicine" },
        { "title": "Science", "value": "Science" },
        { "title": "Social Sciences", "value": "Social Sciences" },
        { "title": "School of Computing and Data Science", "value": "School of Computing and Data Science" }
      ]
    },
    { "type": "TextBlock", "text": "Programme", "wrap": true },
    {
      "type": "Input.Text",
      "id": "programme",
      "placeholder": "e.g. Bachelor of Engineering in Computer Science"
    },
    { "type": "TextBlock", "text": "Year of Study", "wrap": true },
    {
      "type": "Input.ChoiceSet",
      "id": "year_of_study",
      "style": "compact",
      "choices": [
        { "title": "Year 1", "value": "1" },
        { "title": "Year 2", "value": "2" },
        { "title": "Year 3", "value": "3" },
        { "title": "Year 4", "value": "4" },
        { "title": "Year 5+", "value": "5" },
        { "title": "Postgraduate", "value": "postgraduate" }
      ]
    },
    { "type": "TextBlock", "text": "Current CGPA (leave blank if first semester)", "wrap": true },
    {
      "type": "Input.Text",
      "id": "gpa",
      "placeholder": "e.g. 3.7"
    },
    { "type": "TextBlock", "text": "Student Status", "wrap": true },
    {
      "type": "Input.ChoiceSet",
      "id": "local_status",
      "style": "compact",
      "value": "local",
      "choices": [
        { "title": "Local (Hong Kong)", "value": "local" },
        { "title": "Non-local", "value": "non-local" }
      ]
    },
    { "type": "TextBlock", "text": "Country / Place of Origin (if non-local)", "wrap": true },
    {
      "type": "Input.Text",
      "id": "country_of_origin",
      "placeholder": "e.g. Mainland China, United Kingdom"
    },
    { "type": "TextBlock", "text": "Include need-based scholarships in my matches?", "wrap": true },
    {
      "type": "Input.ChoiceSet",
      "id": "financial_need_opt_in",
      "style": "compact",
      "value": "false",
      "choices": [
        { "title": "Yes", "value": "true" },
        { "title": "No", "value": "false" }
      ]
    },
    { "type": "TextBlock", "text": "Interests (comma-separated)", "wrap": true },
    {
      "type": "Input.Text",
      "id": "interests",
      "placeholder": "e.g. AI, robotics, hackathons, creative writing"
    },
    { "type": "TextBlock", "text": "Activities & Achievements", "wrap": true },
    {
      "type": "Input.Text",
      "id": "activities",
      "isMultiline": true,
      "placeholder": "e.g. HKU Robotics Team, Dean's List, volunteer work"
    },
    {
      "type": "TextBlock",
      "text": "Module Opt-ins",
      "weight": "Bolder",
      "separator": true
    },
    {
      "type": "Input.Toggle",
      "id": "module_scholarships",
      "title": "Scholarship Matching & Drafting",
      "value": "true",
      "valueOn": "true",
      "valueOff": "false"
    },
    {
      "type": "Input.Toggle",
      "id": "module_events",
      "title": "External Events",
      "value": "true",
      "valueOn": "true",
      "valueOff": "false"
    },
    {
      "type": "Input.Toggle",
      "id": "module_inbox",
      "title": "Smart Inbox Management",
      "value": "true",
      "valueOn": "true",
      "valueOff": "false"
    },
    {
      "type": "TextBlock",
      "text": "Notification Preference",
      "weight": "Bolder",
      "separator": true
    },
    { "type": "TextBlock", "text": "Frequency", "wrap": true },
    {
      "type": "Input.ChoiceSet",
      "id": "notification_preference",
      "style": "compact",
      "value": "daily_morning",
      "choices": [
        { "title": "Daily Morning Digest", "value": "daily_morning" },
        { "title": "Weekly Summary", "value": "weekly_summary" },
        { "title": "Only Urgent Alerts", "value": "urgent_only" }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Timetable",
      "weight": "Bolder",
      "separator": true
    },
    {
      "type": "TextBlock",
      "text": "Optional: add up to 3 regular classes so I can flag event conflicts.",
      "wrap": true,
      "size": "Small"
    },
    { "type": "TextBlock", "text": "Class 1 Course Code", "wrap": true },
    { "type": "Input.Text", "id": "class1_code", "placeholder": "e.g. COMP3230" },
    { "type": "TextBlock", "text": "Class 1 Day", "wrap": true },
    { "type": "Input.ChoiceSet", "id": "class1_day", "style": "compact", "choices": [ { "title": "Mon", "value": "Monday" }, { "title": "Tue", "value": "Tuesday" }, { "title": "Wed", "value": "Wednesday" }, { "title": "Thu", "value": "Thursday" }, { "title": "Fri", "value": "Friday" } ] },
    { "type": "TextBlock", "text": "Class 1 Start", "wrap": true },
    { "type": "Input.ChoiceSet", "id": "class1_start", "style": "compact", "choices": [ { "title": "09:00", "value": "09:00" }, { "title": "10:00", "value": "10:00" }, { "title": "11:00", "value": "11:00" }, { "title": "12:00", "value": "12:00" }, { "title": "13:00", "value": "13:00" }, { "title": "14:00", "value": "14:00" }, { "title": "15:00", "value": "15:00" }, { "title": "16:00", "value": "16:00" }, { "title": "17:00", "value": "17:00" }, { "title": "18:00", "value": "18:00" } ] },
    { "type": "TextBlock", "text": "Class 1 End", "wrap": true },
    { "type": "Input.ChoiceSet", "id": "class1_end", "style": "compact", "choices": [ { "title": "10:00", "value": "10:00" }, { "title": "11:00", "value": "11:00" }, { "title": "12:00", "value": "12:00" }, { "title": "13:00", "value": "13:00" }, { "title": "14:00", "value": "14:00" }, { "title": "15:00", "value": "15:00" }, { "title": "16:00", "value": "16:00" }, { "title": "17:00", "value": "17:00" }, { "title": "18:00", "value": "18:00" }, { "title": "19:00", "value": "19:00" } ] },
    { "type": "TextBlock", "text": "Class 2 Course Code", "wrap": true },
    { "type": "Input.Text", "id": "class2_code", "placeholder": "Optional" },
    { "type": "TextBlock", "text": "Class 2 Day", "wrap": true },
    { "type": "Input.ChoiceSet", "id": "class2_day", "style": "compact", "choices": [ { "title": "Mon", "value": "Monday" }, { "title": "Tue", "value": "Tuesday" }, { "title": "Wed", "value": "Wednesday" }, { "title": "Thu", "value": "Thursday" }, { "title": "Fri", "value": "Friday" } ] },
    { "type": "TextBlock", "text": "Class 2 Start", "wrap": true },
    { "type": "Input.ChoiceSet", "id": "class2_start", "style": "compact", "choices": [ { "title": "09:00", "value": "09:00" }, { "title": "10:00", "value": "10:00" }, { "title": "11:00", "value": "11:00" }, { "title": "12:00", "value": "12:00" }, { "title": "13:00", "value": "13:00" }, { "title": "14:00", "value": "14:00" }, { "title": "15:00", "value": "15:00" }, { "title": "16:00", "value": "16:00" }, { "title": "17:00", "value": "17:00" }, { "title": "18:00", "value": "18:00" } ] },
    { "type": "TextBlock", "text": "Class 2 End", "wrap": true },
    { "type": "Input.ChoiceSet", "id": "class2_end", "style": "compact", "choices": [ { "title": "10:00", "value": "10:00" }, { "title": "11:00", "value": "11:00" }, { "title": "12:00", "value": "12:00" }, { "title": "13:00", "value": "13:00" }, { "title": "14:00", "value": "14:00" }, { "title": "15:00", "value": "15:00" }, { "title": "16:00", "value": "16:00" }, { "title": "17:00", "value": "17:00" }, { "title": "18:00", "value": "18:00" }, { "title": "19:00", "value": "19:00" } ] },
    { "type": "TextBlock", "text": "Class 3 Course Code", "wrap": true },
    { "type": "Input.Text", "id": "class3_code", "placeholder": "Optional" },
    { "type": "TextBlock", "text": "Class 3 Day", "wrap": true },
    { "type": "Input.ChoiceSet", "id": "class3_day", "style": "compact", "choices": [ { "title": "Mon", "value": "Monday" }, { "title": "Tue", "value": "Tuesday" }, { "title": "Wed", "value": "Wednesday" }, { "title": "Thu", "value": "Thursday" }, { "title": "Fri", "value": "Friday" } ] },
    { "type": "TextBlock", "text": "Class 3 Start", "wrap": true },
    { "type": "Input.ChoiceSet", "id": "class3_start", "style": "compact", "choices": [ { "title": "09:00", "value": "09:00" }, { "title": "10:00", "value": "10:00" }, { "title": "11:00", "value": "11:00" }, { "title": "12:00", "value": "12:00" }, { "title": "13:00", "value": "13:00" }, { "title": "14:00", "value": "14:00" }, { "title": "15:00", "value": "15:00" }, { "title": "16:00", "value": "16:00" }, { "title": "17:00", "value": "17:00" }, { "title": "18:00", "value": "18:00" } ] },
    { "type": "TextBlock", "text": "Class 3 End", "wrap": true },
    { "type": "Input.ChoiceSet", "id": "class3_end", "style": "compact", "choices": [ { "title": "10:00", "value": "10:00" }, { "title": "11:00", "value": "11:00" }, { "title": "12:00", "value": "12:00" }, { "title": "13:00", "value": "13:00" }, { "title": "14:00", "value": "14:00" }, { "title": "15:00", "value": "15:00" }, { "title": "16:00", "value": "16:00" }, { "title": "17:00", "value": "17:00" }, { "title": "18:00", "value": "18:00" }, { "title": "19:00", "value": "19:00" } ] },
    {
      "type": "TextBlock",
      "text": "CV Upload: Attach your PDF CV to this chat and type upload cv after submitting this form.",
      "wrap": true,
      "separator": true
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Set up my profile",
      "data": {
        "action": "onboarding_submit"
      }
    }
  ]
}

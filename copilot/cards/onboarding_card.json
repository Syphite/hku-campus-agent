{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Welcome to HKU Campus Agent",
      "size": "Large",
      "weight": "Bolder",
      "color": "Accent",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Set up your profile so I can personalize scholarships, events, and inbox management.",
      "wrap": true,
      "spacing": "Small"
    },
    {
      "type": "TextBlock",
      "text": "Basic Info",
      "weight": "Bolder",
      "spacing": "Large",
      "separator": true
    },
    {
      "type": "Input.ChoiceSet",
      "id": "faculty",
      "label": "Faculty",
      "isRequired": true,
      "errorMessage": "Please select your faculty",
      "style": "compact",
      "choices": [
        { "title": "Architecture", "value": "Architecture" },
        { "title": "Arts", "value": "Arts" },
        { "title": "Business and Economics", "value": "Business and Economics" },
        { "title": "Dentistry", "value": "Dentistry" },
        { "title": "Education", "value": "Education" },
        { "title": "Engineering", "value": "Engineering" },
        { "title": "Law", "value": "Law" },
        { "title": "Medicine", "value": "Medicine" },
        { "title": "Science", "value": "Science" },
        { "title": "Social Sciences", "value": "Social Sciences" },
        { "title": "School of Computing and Data Science", "value": "School of Computing and Data Science" }
      ]
    },
    {
      "type": "Input.Text",
      "id": "programme",
      "label": "Programme",
      "isRequired": true,
      "errorMessage": "Please enter your programme",
      "placeholder": "e.g. Bachelor of Engineering in Computer Science"
    },
    {
      "type": "Input.ChoiceSet",
      "id": "year_of_study",
      "label": "Year of Study",
      "isRequired": true,
      "style": "compact",
      "choices": [
        { "title": "Year 1", "value": "1" },
        { "title": "Year 2", "value": "2" },
        { "title": "Year 3", "value": "3" },
        { "title": "Year 4", "value": "4" },
        { "title": "Year 5+", "value": "5" },
        { "title": "Postgraduate", "value": "postgraduate" }
      ]
    },
    {
      "type": "Input.Number",
      "id": "gpa",
      "label": "Current CGPA (leave blank if first semester)",
      "placeholder": "e.g. 3.7",
      "min": 0,
      "max": 4.3
    },
    {
      "type": "Input.ChoiceSet",
      "id": "local_status",
      "label": "Student Status",
      "style": "compact",
      "value": "local",
      "choices": [
        { "title": "Local (Hong Kong)", "value": "local" },
        { "title": "Non-local", "value": "non-local" }
      ]
    },
    {
      "type": "Input.Text",
      "id": "country_of_origin",
      "label": "Country / Place of Origin (if non-local)",
      "placeholder": "e.g. Mainland China, United Kingdom"
    },
    {
      "type": "Input.ChoiceSet",
      "id": "financial_need_opt_in",
      "label": "Include need-based scholarships in my matches?",
      "style": "compact",
      "value": "false",
      "choices": [
        { "title": "Yes", "value": "true" },
        { "title": "No", "value": "false" }
      ]
    },
    {
      "type": "Input.Text",
      "id": "interests",
      "label": "Interests (comma-separated)",
      "placeholder": "e.g. AI, robotics, hackathons, creative writing"
    },
    {
      "type": "Input.Text",
      "id": "activities",
      "label": "Activities & Achievements",
      "isMultiline": true,
      "placeholder": "e.g. HKU Robotics Team, Dean's List, volunteer work"
    },
    {
      "type": "TextBlock",
      "text": "Module Opt-ins",
      "weight": "Bolder",
      "spacing": "Large",
      "separator": true
    },
    {
      "type": "Input.Toggle",
      "id": "module_scholarships",
      "title": "Scholarship Matching & Drafting",
      "value": "true",
      "valueOn": "true",
      "valueOff": "false"
    },
    {
      "type": "Input.Toggle",
      "id": "module_events",
      "title": "External Events (LinkedIn/Xiaohongshu)",
      "value": "true",
      "valueOn": "true",
      "valueOff": "false"
    },
    {
      "type": "Input.Toggle",
      "id": "module_inbox",
      "title": "Smart Inbox Management",
      "value": "true",
      "valueOn": "true",
      "valueOff": "false"
    },
    {
      "type": "TextBlock",
      "text": "Notification Preference",
      "weight": "Bolder",
      "spacing": "Large",
      "separator": true
    },
    {
      "type": "Input.ChoiceSet",
      "id": "notification_preference",
      "label": "Frequency",
      "style": "compact",
      "value": "daily_morning",
      "choices": [
        { "title": "Daily Morning Digest", "value": "daily_morning" },
        { "title": "Weekly Summary", "value": "weekly_summary" },
        { "title": "Only Urgent Alerts", "value": "urgent_only" }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Timetable",
      "weight": "Bolder",
      "spacing": "Large",
      "separator": true
    },
    {
      "type": "TextBlock",
      "text": "Optional: add up to 3 regular classes so I can flag event conflicts.",
      "wrap": true,
      "size": "Small",
      "spacing": "Small"
    },
    {
      "type": "ColumnSet",
      "columns": [
        { "type": "Column", "width": "stretch", "items": [ { "type": "Input.Text", "id": "class1_code", "placeholder": "Course Code (e.g. COMP3230)" } ] },
        { "type": "Column", "width": "auto", "items": [ { "type": "Input.ChoiceSet", "id": "class1_day", "style": "compact", "placeholder": "Day", "choices": [ { "title": "Mon", "value": "Monday" }, { "title": "Tue", "value": "Tuesday" }, { "title": "Wed", "value": "Wednesday" }, { "title": "Thu", "value": "Thursday" }, { "title": "Fri", "value": "Friday" } ] } ] },
        { "type": "Column", "width": "auto", "items": [ { "type": "Input.ChoiceSet", "id": "class1_start", "style": "compact", "placeholder": "Start", "choices": [ { "title": "09:00", "value": "09:00" }, { "title": "10:00", "value": "10:00" }, { "title": "11:00", "value": "11:00" }, { "title": "12:00", "value": "12:00" }, { "title": "13:00", "value": "13:00" }, { "title": "14:00", "value": "14:00" }, { "title": "15:00", "value": "15:00" }, { "title": "16:00", "value": "16:00" }, { "title": "17:00", "value": "17:00" }, { "title": "18:00", "value": "18:00" } ] } ] },
        { "type": "Column", "width": "auto", "items": [ { "type": "Input.ChoiceSet", "id": "class1_end", "style": "compact", "placeholder": "End", "choices": [ { "title": "10:00", "value": "10:00" }, { "title": "11:00", "value": "11:00" }, { "title": "12:00", "value": "12:00" }, { "title": "13:00", "value": "13:00" }, { "title": "14:00", "value": "14:00" }, { "title": "15:00", "value": "15:00" }, { "title": "16:00", "value": "16:00" }, { "title": "17:00", "value": "17:00" }, { "title": "18:00", "value": "18:00" }, { "title": "19:00", "value": "19:00" } ] } ] }
      ]
    },
    {
      "type": "ColumnSet",
      "columns": [
        { "type": "Column", "width": "stretch", "items": [ { "type": "Input.Text", "id": "class2_code", "placeholder": "Course Code (Optional)" } ] },
        { "type": "Column", "width": "auto", "items": [ { "type": "Input.ChoiceSet", "id": "class2_day", "style": "compact", "placeholder": "Day", "choices": [ { "title": "Mon", "value": "Monday" }, { "title": "Tue", "value": "Tuesday" }, { "title": "Wed", "value": "Wednesday" }, { "title": "Thu", "value": "Thursday" }, { "title": "Fri", "value": "Friday" } ] } ] },
        { "type": "Column", "width": "auto", "items": [ { "type": "Input.ChoiceSet", "id": "class2_start", "style": "compact", "placeholder": "Start", "choices": [ { "title": "09:00", "value": "09:00" }, { "title": "10:00", "value": "10:00" }, { "title": "11:00", "value": "11:00" }, { "title": "12:00", "value": "12:00" }, { "title": "13:00", "value": "13:00" }, { "title": "14:00", "value": "14:00" }, { "title": "15:00", "value": "15:00" }, { "title": "16:00", "value": "16:00" }, { "title": "17:00", "value": "17:00" }, { "title": "18:00", "value": "18:00" } ] } ] },
        { "type": "Column", "width": "auto", "items": [ { "type": "Input.ChoiceSet", "id": "class2_end", "style": "compact", "placeholder": "End", "choices": [ { "title": "10:00", "value": "10:00" }, { "title": "11:00", "value": "11:00" }, { "title": "12:00", "value": "12:00" }, { "title": "13:00", "value": "13:00" }, { "title": "14:00", "value": "14:00" }, { "title": "15:00", "value": "15:00" }, { "title": "16:00", "value": "16:00" }, { "title": "17:00", "value": "17:00" }, { "title": "18:00", "value": "18:00" }, { "title": "19:00", "value": "19:00" } ] } ] }
      ]
    },
    {
      "type": "ColumnSet",
      "columns": [
        { "type": "Column", "width": "stretch", "items": [ { "type": "Input.Text", "id": "class3_code", "placeholder": "Course Code (Optional)" } ] },
        { "type": "Column", "width": "auto", "items": [ { "type": "Input.ChoiceSet", "id": "class3_day", "style": "compact", "placeholder": "Day", "choices": [ { "title": "Mon", "value": "Monday" }, { "title": "Tue", "value": "Tuesday" }, { "title": "Wed", "value": "Wednesday" }, { "title": "Thu", "value": "Thursday" }, { "title": "Fri", "value": "Friday" } ] } ] },
        { "type": "Column", "width": "auto", "items": [ { "type": "Input.ChoiceSet", "id": "class3_start", "style": "compact", "placeholder": "Start", "choices": [ { "title": "09:00", "value": "09:00" }, { "title": "10:00", "value": "10:00" }, { "title": "11:00", "value": "11:00" }, { "title": "12:00", "value": "12:00" }, { "title": "13:00", "value": "13:00" }, { "title": "14:00", "value": "14:00" }, { "title": "15:00", "value": "15:00" }, { "title": "16:00", "value": "16:00" }, { "title": "17:00", "value": "17:00" }, { "title": "18:00", "value": "18:00" } ] } ] },
        { "type": "Column", "width": "auto", "items": [ { "type": "Input.ChoiceSet", "id": "class3_end", "style": "compact", "placeholder": "End", "choices": [ { "title": "10:00", "value": "10:00" }, { "title": "11:00", "value": "11:00" }, { "title": "12:00", "value": "12:00" }, { "title": "13:00", "value": "13:00" }, { "title": "14:00", "value": "14:00" }, { "title": "15:00", "value": "15:00" }, { "title": "16:00", "value": "16:00" }, { "title": "17:00", "value": "17:00" }, { "title": "18:00", "value": "18:00" }, { "title": "19:00", "value": "19:00" } ] } ] }
      ]
    },
    {
      "type": "TextBlock",
      "text": "💡 **CV Upload:** Attach your PDF CV to this chat and type `upload cv` after submitting this form.",
      "wrap": true,
      "spacing": "Large",
      "separator": true,
      "color": "Accent"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Set up my profile",
      "style": "positive",
      "data": {
        "action": "onboarding_submit"
      }
    }
  ]
} 

{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.4",
  "body": [
    {
      "type": "TextBlock",
      "text": "Welcome to HKU Campus Agent",
      "size": "Large",
      "weight": "Bolder",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Set up your profile so I can personalize scholarships, events, and inbox management.",
      "wrap": true
    },
    {
      "type": "Input.Text",
      "id": "name",
      "label": "Display Name * (required)",
      "placeholder": "e.g. Alex Chen",
      "spacing": "Medium"
    },
    {
      "type": "TextBlock",
      "text": "Basic Info",
      "size": "Medium",
      "weight": "Bolder",
      "separator": true,
      "spacing": "Medium"
    },
    {
      "type": "Input.ChoiceSet",
      "id": "faculty",
      "label": "Faculty * (required)",
      "style": "compact",
      "choices": [
        { "title": "Architecture", "value": "Architecture" },
        { "title": "Arts", "value": "Arts" },
        { "title": "Business and Economics", "value": "Business and Economics" },
        { "title": "Dentistry", "value": "Dentistry" },
        { "title": "Education", "value": "Education" },
        { "title": "Engineering", "value": "Engineering" },
        { "title": "Law", "value": "Law" },
        { "title": "Medicine", "value": "Medicine" },
        { "title": "Science", "value": "Science" },
        { "title": "Social Sciences", "value": "Social Sciences" },
        { "title": "School of Computing and Data Science", "value": "School of Computing and Data Science" }
      ]
    },
    {
      "type": "Input.Text",
      "id": "programme",
      "label": "Programme * (required)",
      "placeholder": "e.g. Bachelor of Engineering in Computer Science"
    },
    {
      "type": "Input.ChoiceSet",
      "id": "year_of_study",
      "label": "Year of Study * (required)",
      "style": "compact",
      "choices": [
        { "title": "Year 1", "value": "1" },
        { "title": "Year 2", "value": "2" },
        { "title": "Year 3", "value": "3" },
        { "title": "Year 4", "value": "4" },
        { "title": "Year 5+", "value": "5" },
        { "title": "Postgraduate", "value": "postgraduate" }
      ]
    },
    {
      "type": "Input.ChoiceSet",
      "id": "local_status",
      "label": "Student Status * (required)",
      "style": "compact",
      "value": "local",
      "choices": [
        { "title": "Local (Hong Kong)", "value": "local" },
        { "title": "Non-local", "value": "non-local" }
      ]
    },
    {
      "type": "Input.Text",
      "id": "gpa",
      "label": "CGPA (Optional)",
      "placeholder": "e.g. 3.7"
    },
    {
      "type": "Input.ChoiceSet",
      "id": "financial_need_opt_in",
      "label": "Financial Need (Optional)",
      "style": "compact",
      "choices": [
        { "title": "Yes", "value": "true" },
        { "title": "No", "value": "false" }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Interests & Activities",
      "size": "Medium",
      "weight": "Bolder",
      "separator": true,
      "spacing": "Medium"
    },
    {
      "type": "Input.Text",
      "id": "interests",
      "label": "Interests * (required)",
      "placeholder": "e.g. AI, robotics, hackathons, creative writing"
    },
    {
      "type": "Input.Text",
      "id": "activities",
      "label": "Activities & Achievements (Optional)",
      "isMultiline": true,
      "placeholder": "e.g. HKU Robotics Team, Dean's List, volunteer work"
    },
    {
      "type": "TextBlock",
      "text": "Module Opt-ins * (select at least one)",
      "size": "Medium",
      "weight": "Bolder",
      "separator": true,
      "spacing": "Medium"
    },
    {
      "type": "Input.Toggle",
      "id": "module_scholarships",
      "title": "Scholarship Matching & Drafting",
      "value": "true",
      "valueOn": "true",
      "valueOff": "false"
    },
    {
      "type": "TextBlock",
      "text": "💡 If you enable Scholarship Matching, I'll ask you for your CGPA and financial need information in the next step to find the best matches.",
      "wrap": true,
      "spacing": "Small"
    },
    {
      "type": "Input.Toggle",
      "id": "module_events",
      "title": "External Events",
      "value": "true",
      "valueOn": "true",
      "valueOff": "false"
    },
    {
      "type": "Input.Toggle",
      "id": "module_inbox",
      "title": "Smart Inbox Management",
      "value": "true",
      "valueOn": "true",
      "valueOff": "false"
    },
    {
      "type": "TextBlock",
      "text": "Notification Preference",
      "size": "Medium",
      "weight": "Bolder",
      "separator": true,
      "spacing": "Medium"
    },
    {
      "type": "Input.ChoiceSet",
      "id": "notification_preference",
      "label": "Frequency",
      "style": "compact",
      "value": "daily_morning",
      "choices": [
        { "title": "Daily Morning Digest", "value": "daily_morning" },
        { "title": "Weekly Summary", "value": "weekly_summary" },
        { "title": "Only Urgent Alerts", "value": "urgent_only" }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Timetable (Optional - add if you want conflict checking)",
      "size": "Medium",
      "weight": "Bolder",
      "separator": true,
      "spacing": "Medium"
    },
    {
      "type": "TextBlock",
      "text": "Add your first regular class. You can add more rows later.",
      "wrap": true,
      "size": "Small"
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "Input.Text",
              "id": "class1_code",
              "label": "Course Code",
              "placeholder": "e.g. COMP3230"
            }
          ]
        },
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "Input.ChoiceSet",
              "id": "class1_day",
              "label": "Day",
              "style": "compact",
              "choices": [
                { "title": "Mon", "value": "Monday" },
                { "title": "Tue", "value": "Tuesday" },
                { "title": "Wed", "value": "Wednesday" },
                { "title": "Thu", "value": "Thursday" },
                { "title": "Fri", "value": "Friday" }
              ]
            }
          ]
        },
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "Input.ChoiceSet",
              "id": "class1_start",
              "label": "Start",
              "style": "compact",
              "choices": [
                { "title": "09:00", "value": "09:00" },
                { "title": "10:00", "value": "10:00" },
                { "title": "11:00", "value": "11:00" },
                { "title": "12:00", "value": "12:00" },
                { "title": "13:00", "value": "13:00" },
                { "title": "14:00", "value": "14:00" },
                { "title": "15:00", "value": "15:00" },
                { "title": "16:00", "value": "16:00" },
                { "title": "17:00", "value": "17:00" },
                { "title": "18:00", "value": "18:00" }
              ]
            }
          ]
        },
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "Input.ChoiceSet",
              "id": "class1_end",
              "label": "End",
              "style": "compact",
              "choices": [
                { "title": "10:00", "value": "10:00" },
                { "title": "11:00", "value": "11:00" },
                { "title": "12:00", "value": "12:00" },
                { "title": "13:00", "value": "13:00" },
                { "title": "14:00", "value": "14:00" },
                { "title": "15:00", "value": "15:00" },
                { "title": "16:00", "value": "16:00" },
                { "title": "17:00", "value": "17:00" },
                { "title": "18:00", "value": "18:00" },
                { "title": "19:00", "value": "19:00" }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "ActionSet",
      "actions": [
        {
          "type": "Action.Submit",
          "title": "➕ Add Another Class",
          "data": {
            "action": "add_timetable_row"
          }
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "CV Upload (Optional)",
      "size": "Medium",
      "weight": "Bolder",
      "separator": true,
      "spacing": "Medium"
    },
    {
      "type": "TextBlock",
      "text": "CV Upload: Attach your PDF CV to this chat and type upload cv after submitting this form.",
      "wrap": true,
      "color": "Good"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Set up my profile",
      "data": {
        "action": "onboarding_submit"
      }
    }
  ]
}
